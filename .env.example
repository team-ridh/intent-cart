# Intent Cart — Environment Variables

# ─────────────────────────────────────────────────────────────────
# COPY THIS FILE:  cp .env.example .env.local
# NEVER commit .env.local to git — it's already in .gitignore
#
# ⚠️  AMPLIFY NOTE: Variables starting with "AWS_" are RESERVED by
#     Amplify and will cause a build error. Use BEDROCK_ prefix instead.
# ─────────────────────────────────────────────────────────────────

# ── AWS Credentials ───────────────────────────────────────────────
# Prefix: BEDROCK_ (NOT AWS_ — reserved by Amplify hosting)
# IAM user needs:
#   - bedrock:InvokeModel (Claude Haiku 4.5)
#   - dynamodb:GetItem, PutItem, UpdateItem on intent-cart-sessions
#   - s3:PutObject, s3:GetObject on intent-cart-uploads-*
BEDROCK_ACCESS_KEY_ID=
BEDROCK_SECRET_ACCESS_KEY=
BEDROCK_REGION=us-east-1

# ── Bedrock Model ───────────────────────────────────────────────────
# Amazon Nova 2 Lite — multimodal (text+image+video), cost-efficient,
# 1M token context window, optimized for high-volume applications.
# Cross-region inference profile prefix "us." is required.
# Enable in: AWS Console → Bedrock → Model access → Amazon → Nova 2 Lite
BEDROCK_MODEL_ID=us.amazon.nova-2-lite-v1:0

# ── DynamoDB ──────────────────────────────────────────────────────
# Table: intent-cart-sessions
# PK: sessionId (String) | TTL attribute: expiresAt | Billing: PAY_PER_REQUEST
# See README.md for creation steps
DYNAMO_TABLE=intent-cart-sessions

# ── S3 ────────────────────────────────────────────────────────────
# Bucket for photo uploads. CORS must be configured — see README.md.
# Replace {accountId} with your 12-digit AWS account ID.
S3_BUCKET=intent-cart-uploads-{accountId}

# ── App Config ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Intent Cart
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_S3_REGION=us-east-1
NEXT_PUBLIC_S3_BUCKET=intent-cart-uploads-{accountId}
