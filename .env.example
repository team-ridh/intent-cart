# Amazon Now OS — Environment Variables

# ─────────────────────────────────────────────────────────────────
# COPY THIS FILE:  cp .env.example .env.local
# NEVER commit .env.local to git — it's already in .gitignore
#
# ⚠️  AMPLIFY NOTE: Variables starting with "AWS_" are RESERVED by
#     Amplify and will cause a build error. Use BEDROCK_ prefix instead.
# ─────────────────────────────────────────────────────────────────

# ── AWS Credentials for Amazon Bedrock ───────────────────────────
# Prefix: BEDROCK_ (NOT AWS_ — reserved by Amplify hosting)
# Create IAM user → attach AmazonBedrockFullAccess policy
# Get keys: AWS Console → IAM → Users → Security Credentials
BEDROCK_ACCESS_KEY_ID=
BEDROCK_SECRET_ACCESS_KEY=
BEDROCK_REGION=us-east-1

# ── Bedrock Model ─────────────────────────────────────────────────
# Claude Haiku 4.5 — active non-legacy model, fastest, cross-region
# "us." prefix = cross-region inference profile (required for 4.x models)
# DO NOT use: anthropic.claude-3-haiku-20240307-v1:0 (Legacy — blocked)
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── App Config ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Amazon Now OS
NEXT_PUBLIC_APP_ENV=production
