# Amazon Now OS — Environment Variables

# ─────────────────────────────────────────────────────────────────
# COPY THIS FILE:  cp .env.example .env.local
# NEVER commit .env.local to git — it's already in .gitignore
# ─────────────────────────────────────────────────────────────────

# ── AWS Credentials (for Amazon Bedrock AI) ──────────────────────
# Create an IAM user with BedrockFullAccess or a custom policy:
#   Action:   bedrock:InvokeModel
#   Resource: arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-haiku-20240307-v1:0
#
# Get keys from: AWS Console → IAM → Users → Security Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Bedrock Model ─────────────────────────────────────────────────
# Claude 3 Haiku is now LEGACY — use Claude 3.5 Haiku instead
# Claude 3.5 Haiku: fast + cheap (recommended for intent extraction)
# Claude 3.5 Sonnet: more powerful (use if you need richer reasoning)
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# ── App Config ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Amazon Now OS
NEXT_PUBLIC_APP_ENV=production
