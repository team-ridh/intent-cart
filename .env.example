# Amazon Now OS — Environment Variables

# ─────────────────────────────────────────────────────────────────
# COPY THIS FILE:  cp .env.example .env.local
# NEVER commit .env.local to git — it's already in .gitignore
# ─────────────────────────────────────────────────────────────────

# ── AWS Credentials (for Amazon Bedrock AI) ──────────────────────
# Create an IAM user with BedrockFullAccess or a custom policy:
#   Action:   bedrock:InvokeModel
#   Resource: arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-haiku-20240307-v1:0
#
# Get keys from: AWS Console → IAM → Users → Security Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Bedrock Model ─────────────────────────────────────────────────
# Claude Haiku 4.5 — current non-legacy, fastest, cross-region inference
# Cross-region profile ("us." prefix) routes across us-east-1 + us-west-2
# DO NOT use: anthropic.claude-3-haiku-20240307-v1:0 (Legacy — blocked)
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── Optional: AWS Session Token (only needed for temporary credentials) ──
# AWS_SESSION_TOKEN=

# ── App Config ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Amazon Now OS
NEXT_PUBLIC_APP_ENV=production
