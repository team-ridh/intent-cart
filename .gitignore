# ─── Dependencies ────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js build output ────────────────────────────────────────
.next/
out/
build/

# ─── Environment variables — NEVER commit these ──────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is intentionally NOT ignored (it's the template)

# ─── Testing ─────────────────────────────────────────────────────
coverage/

# ─── TypeScript ──────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Debug logs ──────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── macOS ───────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ─── IDE / Editor ────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── AWS / Amplify ───────────────────────────────────────────────
.amplify/
amplify/
#amplify.yml is intentionally NOT ignored (CI/CD config)

# ─── Deployment ──────────────────────────────────────────────────
.vercel

# ─── Misc ────────────────────────────────────────────────────────
*.pem
*.log

/scripts/